{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "esModuleInterop": true,
    "outDir": "./js",
    "rootDir": "./js",
    "sourceMap": true
  },
  "include": ["js/**/*.ts"],
  "exclude": ["node_modules"]
}
